{
  "name": "mcp-saas-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Demo MCP server for a multi-tenant SaaS — SQL-as-interface, use-case tools, tenant-scoped read-only access. Implements the 2026 MCP server patterns.",
  "bin": { "mcp-saas-demo": "./build/server.js" },
  "scripts": {
    "build": "tsc",
    "start": "node --no-warnings build/server.js",
    "smoke": "node build/smoke.js",
    "test:client": "node build/client-test.js",
    "inspect": "npx @modelcontextprotocol/inspector node build/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0"
  }
}
